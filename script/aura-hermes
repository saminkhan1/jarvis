#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
HERMES_AGENT_DIR="$ROOT_DIR/.aura/hermes-agent"
HERMES_PYTHON="$HERMES_AGENT_DIR/venv/bin/python3"

telemetry_log() {
  local priority="$1"
  local event="$2"
  shift 2

  local severity="info"
  case "$priority" in
    *.err|*.error)
      severity="error"
      ;;
    *.warning|*.warn)
      severity="warning"
      ;;
  esac

  local payload
  payload="$(
    /usr/bin/python3 - "$event" "$severity" "$$" "$@" <<'PY'
import json
import os
import sys
import time

event = sys.argv[1]
severity = sys.argv[2]
pid = int(sys.argv[3])
fields = {}

for item in sys.argv[4:]:
    if "=" not in item:
        continue
    key, value = item.split("=", 1)
    if value.lower() in {"true", "false"}:
        fields[key] = value.lower() == "true"
    else:
        try:
            fields[key] = int(value)
        except ValueError:
            fields[key] = value

payload = {
    "schema_version": 1,
    "event": event,
    "severity": severity,
    "app_session_id": os.environ.get("AURA_APP_SESSION_ID", "none"),
    "trace_id": os.environ.get("AURA_TRACE_ID", "none"),
    "mission_id": os.environ.get("AURA_MISSION_ID", "none"),
    "process_id": pid,
    "process_kind": os.environ.get("AURA_PROCESS_KIND", "wrapper"),
    **fields,
}
print(json.dumps(payload, separators=(",", ":"), sort_keys=True))

ledger_path = os.environ.get("AURA_AUDIT_LEDGER_PATH")
if ledger_path and event in {
    "hermes_wrapper_missing_python",
    "hermes_wrapper_quiet_start",
    "hermes_wrapper_quiet_finish",
    "hermes_wrapper_exec",
}:
    audit = dict(payload)
    audit["recorded_at"] = time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime())
    audit["category"] = "Hermes"
    audit["audit_kind"] = "agent"
    os.makedirs(os.path.dirname(ledger_path), exist_ok=True)
    with open(ledger_path, "a", encoding="utf-8") as fh:
        fh.write(json.dumps(audit, separators=(",", ":"), sort_keys=True) + "\n")
PY
  )"

  if command -v logger >/dev/null 2>&1; then
    logger -p "$priority" -t AURA.Hermes "$payload"
  fi
}

if [[ ! -x "$HERMES_PYTHON" ]]; then
  HERMES_PYTHON="$HERMES_AGENT_DIR/venv/bin/python"
fi

if [[ ! -x "$HERMES_PYTHON" ]]; then
  telemetry_log user.err hermes_wrapper_missing_python path_kind=project_local_hermes_python
  echo "Missing project-local Hermes Python at $HERMES_AGENT_DIR/venv/bin/python3" >&2
  echo "Run: cd \"$ROOT_DIR\" && ./script/setup.sh" >&2
  exit 127
fi

export AURA_PROJECT_ROOT="$ROOT_DIR"
export HOME="$ROOT_DIR/.aura/home"
export HERMES_HOME="$ROOT_DIR/.aura/hermes-home"
export VIRTUAL_ENV="$HERMES_AGENT_DIR/venv"
export PATH="$VIRTUAL_ENV/bin:$PATH"
export PYTHONPATH="$HERMES_AGENT_DIR${PYTHONPATH:+:$PYTHONPATH}"
export PYTHONNOUSERSITE=1

is_quiet_chat=0
session_source=""
operation="${1:-none}"
if [[ "${1:-}" == "chat" ]]; then
  operation="chat.start"
  args=("$@")
  for ((i = 0; i < ${#args[@]}; i++)); do
    case "${args[$i]}" in
      -Q|--quiet)
        is_quiet_chat=1
        ;;
      --source)
        if (( i + 1 < ${#args[@]} )); then
          session_source="${args[$((i + 1))]}"
        fi
        ;;
      --source=*)
        session_source="${args[$i]#--source=}"
        ;;
      --resume)
        operation="chat.resume"
        ;;
    esac
  done
fi

print_aura_voice_doctor() {
  "$HERMES_PYTHON" - <<'PY'
from tools.voice_mode import check_voice_requirements

print()
print("◆ AURA Hermes Voice Mode")
try:
    requirements = check_voice_requirements()
except Exception as exc:
    print(f"  ⚠ Hermes check_voice_requirements failed: {type(exc).__name__}")
    print("    → Use /voice status inside Hermes for the runtime error detail.")
else:
    symbol = "✓" if requirements.get("available") else "⚠"
    print(f"  {symbol} Hermes check_voice_requirements available: {requirements.get('available')}")
    print(f"  {'✓' if requirements.get('audio_available') else '⚠'} Audio capture available: {requirements.get('audio_available')}")
    print(f"  {'✓' if requirements.get('stt_available') else '⚠'} STT available: {requirements.get('stt_available')}")
    missing = requirements.get("missing_packages") or []
    if missing:
        print(f"  ⚠ Missing packages: {', '.join(missing)}")
    details = str(requirements.get("details") or "").strip()
    if details:
        for detail in details.splitlines():
            print(f"    → {detail}")

print("  → CLI commands: /voice status, /voice on, /voice off, /voice tts")
print("  → AURA can capture in-app microphone audio and passes a temporary WAV to project-local Hermes for STT.")
PY
}

should_log_wrapper_exec() {
  [[ "${AURA_SKIP_WRAPPER_EXEC_TELEMETRY:-0}" != "1" ]]
}

if [[ "$is_quiet_chat" == "1" ]]; then
  started_epoch_ms="$(/usr/bin/python3 -c 'import time; print(round(time.time() * 1000))')"
  telemetry_log user.info hermes_wrapper_quiet_start operation="$operation" source="${session_source:-none}"

  stdout_file="$(mktemp "${TMPDIR:-/tmp}/aura-hermes-stdout.XXXXXX")"
  stderr_file="$(mktemp "${TMPDIR:-/tmp}/aura-hermes-stderr.XXXXXX")"
  child_pid=""
  killer_pid=""
  termination_reason="completed"
  emitted_output=0

  cleanup() {
    rm -f "$stdout_file" "$stderr_file"
  }
  trap cleanup EXIT

  signal_exit_code() {
    case "$1" in
      INT) echo 130 ;;
      HUP) echo 129 ;;
      TERM|*) echo 143 ;;
    esac
  }

  request_child_termination() {
    local signal_name="$1"
    termination_reason="signal_${signal_name}"
    trap - INT TERM HUP

    if [[ -n "$child_pid" ]]; then
      kill -TERM "$child_pid" >/dev/null 2>&1 || true
      (
        sleep 15
        if kill -0 "$child_pid" >/dev/null 2>&1; then
          kill -KILL "$child_pid" >/dev/null 2>&1 || true
        fi
      ) &
      killer_pid="$!"
    fi
  }

  emit_quiet_output_once() {
    if [[ "$emitted_output" == "1" ]]; then
      return 0
    fi

    emitted_output=1
    cat "$stdout_file"
    cat "$stderr_file" >&2
  }

  finish_quiet_chat() {
    local status="$1"
    local session_id
    local finished_epoch_ms
    local duration_ms

    emit_quiet_output_once
    session_id="$(
      awk -F': *' 'tolower($1) == "session_id" { print $2; exit }' \
        "$stderr_file" "$stdout_file" | tr -d '\r'
    )"
    finished_epoch_ms="$(/usr/bin/python3 -c 'import time; print(round(time.time() * 1000))')"
    duration_ms="$((finished_epoch_ms - started_epoch_ms))"
    if [[ "$status" == "0" ]]; then
      telemetry_log user.info hermes_wrapper_quiet_finish operation="$operation" exit_code="$status" duration_ms="$duration_ms" hermes_session_id="${session_id:-none}" termination_reason="$termination_reason"
    else
      telemetry_log user.err hermes_wrapper_quiet_finish operation="$operation" exit_code="$status" duration_ms="$duration_ms" hermes_session_id="${session_id:-none}" termination_reason="$termination_reason"
    fi
  }

  trap 'request_child_termination INT' INT
  trap 'request_child_termination TERM' TERM
  trap 'request_child_termination HUP' HUP

  set +e
  "$HERMES_PYTHON" -m hermes_cli.main "$@" >"$stdout_file" 2>"$stderr_file" &
  child_pid="$!"
  wait "$child_pid"
  status=$?
  if [[ "$termination_reason" == signal_* ]]; then
    wait "$child_pid" >/dev/null 2>&1
    child_status="$?"
    if [[ "$child_status" != "0" ]]; then
      status="$child_status"
    else
      status="$(signal_exit_code "${termination_reason#signal_}")"
    fi
  elif (( status >= 128 )); then
    termination_reason="child_signal_$((status - 128))"
  fi
  if [[ -n "$killer_pid" ]]; then
    kill "$killer_pid" >/dev/null 2>&1 || true
    wait "$killer_pid" >/dev/null 2>&1 || true
  fi
  set -e

  finish_quiet_chat "$status"
  exit "$status"
fi

if [[ "${1:-}" == "aura-transcribe-audio" ]]; then
  audio_path="${2:-}"
  if [[ -z "$audio_path" || ! -f "$audio_path" ]]; then
    echo "usage: ./script/aura-hermes aura-transcribe-audio <audio-file>" >&2
    exit 2
  fi

  if should_log_wrapper_exec; then
    telemetry_log user.info hermes_wrapper_exec operation="voice.transcribe" source="${session_source:-none}"
  fi
  "$HERMES_PYTHON" - "$audio_path" <<'PY'
import json
import os
import sys
from pathlib import Path

audio_path = sys.argv[1]
try:
    from hermes_cli.env_loader import load_hermes_dotenv

    project_root = Path(os.environ.get("AURA_PROJECT_ROOT", "."))
    load_hermes_dotenv(project_env=project_root / ".env")

    from tools.voice_mode import transcribe_recording

    result = transcribe_recording(audio_path)
except Exception as exc:
    result = {
        "success": False,
        "error": f"{type(exc).__name__}: {exc}",
    }

print(json.dumps(result, separators=(",", ":"), sort_keys=True))
PY
  exit $?
fi

if [[ "${1:-}" == "doctor" ]]; then
  if should_log_wrapper_exec; then
    telemetry_log user.info hermes_wrapper_exec operation="$operation" source="${session_source:-none}"
  fi
  set +e
  "$HERMES_PYTHON" -m hermes_cli.main "$@"
  status=$?
  set -e
  print_aura_voice_doctor
  exit "$status"
fi

if should_log_wrapper_exec; then
  telemetry_log user.info hermes_wrapper_exec operation="$operation" source="${session_source:-none}"
fi
exec "$HERMES_PYTHON" -m hermes_cli.main "$@"
