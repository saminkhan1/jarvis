# AURA repo-backed Hermes environment template.
#
# script/setup.sh copies this file to .aura/hermes-home/.env only when that
# local file does not already exist. Put real secrets only in the local copy.

# Primary provider options. Use ./script/aura-hermes setup or edit
# .aura/hermes-home/config.yaml to choose the provider/model.
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# GEMINI_API_KEY=
# GLM_API_KEY=
# KIMI_API_KEY=
# MINIMAX_API_KEY=

# Optional web/research providers for Hermes web tools.
# EXA_API_KEY=
# PARALLEL_API_KEY=
# TAVILY_API_KEY=
# FIRECRAWL_API_KEY=
# FIRECRAWL_API_URL=

# Optional browser/cloud tool providers.
# BROWSERBASE_API_KEY=
# BROWSERBASE_PROJECT_ID=
# FAL_KEY=
# GITHUB_TOKEN=

# Terminal behavior is primarily configured in config.yaml.
TERMINAL_TIMEOUT=60
TERMINAL_LIFETIME_SECONDS=300
